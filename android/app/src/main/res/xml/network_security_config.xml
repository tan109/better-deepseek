<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext (HTTP, not HTTPS) is blocked globally by
         usesCleartextTraffic="false" in AndroidManifest.xml. This carves
         out a narrow exception for the /termux command's local server,
         which only ever runs on this same device; everything else
         (real internet traffic, OAuth proxy, etc.) stays HTTPS-only. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
